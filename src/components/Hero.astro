<section id="inicio" class="min-h-screen flex flex-col justify-center items-start px-8 md:px-20 pt-20 relative overflow-hidden">

    <!-- Fondo decorativo -->
    <div class="absolute right-0 top-0 w-1/2 h-full opacity-10 pointer-events-none">
      <div class="w-full h-full" style="background: radial-gradient(circle at 70% 50%, #ffffff 0%, transparent 70%);"></div>
    </div>
  
    <p class="fade-up fade-up-1 font-['DM_Sans'] text-xs tracking-[0.5em] uppercase text-white/30 mb-6">
      Nueva colección 2025
    </p>
    <h1 class="fade-up fade-up-2 font-['Bebas_Neue'] text-7xl md:text-[10rem] leading-none text-white mb-4">
      Viste<br/>tus pies<br/><span class="text-white/20">con estilo</span>
    </h1>
    <div class="fade-up fade-up-3 h-px w-24 bg-white/20 mb-8"></div>
    <p class="fade-up fade-up-3 font-['DM_Sans'] text-sm text-white/40 mb-10 max-w-sm leading-relaxed">
      Los mejores diseños de calzado al mejor precio. Selecciona tus favoritos y pide directo por WhatsApp.
    </p>
    <a href="#productos" class="fade-up fade-up-3 font-['DM_Sans'] text-xs tracking-widest uppercase bg-white text-black px-10 py-4 hover:bg-white/80 transition-all duration-300">
      Ver productos
    </a>
  </section>